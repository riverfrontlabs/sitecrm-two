# Copy to `.env` (same directory) to configure local development.
# The server loads this file automatically on startup if it exists;
# every variable is optional. See src/server.ts for the full reference.

# Connect to the Postgres container from the repo's docker-compose.yml
# (`docker compose up -d db`). Leave unset to use the in-memory store.
DATABASE_URL=postgres://sitetwo:sitetwo@localhost:5432/sitetwo

# PORT=3001
# HOST=127.0.0.1
