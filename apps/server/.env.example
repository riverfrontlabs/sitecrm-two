# apps/server local environment variables.
# Copy to .env in this directory (apps/server/.env) for local development
# outside Docker. See src/server.ts for the full reference.
#
# Prefer the root .env for Docker Compose runs — this file is for
# `npm run dev:api` directly on the host.

# Connect to the Docker Compose Postgres instance (`docker compose up -d db`).
DATABASE_URL=postgres://sitecrm:sitecrm@localhost:5432/sitecrm

# Required: JWT signing secret. Must match what the frontend sends tokens against.
JWT_SECRET=change-me-to-a-strong-random-secret

# Optional overrides
# PORT=3000
# HOST=127.0.0.1
