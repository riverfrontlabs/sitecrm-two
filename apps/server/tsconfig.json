{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    /* NodeNext = run the emitted JS directly on Node as ESM. This is why
       relative imports in src/ carry explicit `.js` extensions. */
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "types": ["node"]
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts"]
}
