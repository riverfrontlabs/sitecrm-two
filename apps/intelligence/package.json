    "@fastify/swagger-ui": "^5.2.0",
    "@sitecrm/types": "*",
    "fastify": "^5.2.0",
    "openai": "^4.0.0",
    "playwright": "^1.49.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
