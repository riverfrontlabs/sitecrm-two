# Intelligence API environment variables
# Copy to .env and fill in values for local development.

# Required: OpenAI API key for lead scoring and content generation
OPENAI_API_KEY=sk-...

# Optional overrides
PORT=3001
HOST=127.0.0.1

# Restrict CORS to the main server in production; leave unset for dev (allows *)
# CORS_ORIGIN=http://api.localhost
