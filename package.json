{
  "name": "sitetwo-oh",
  "version": "0.1.0",
  "private": true,
  "description": "Full-stack TypeScript application: React + Tailwind frontend, Fastify REST API, and a themeable design system.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "npm run dev -w @sitetwo/web",
    "dev:api": "npm run dev -w @sitetwo/server",
    "build": "npm run build -ws --if-present",
    "test": "npm run test -ws --if-present",
    "typecheck": "npm run typecheck -ws --if-present",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.5.0",
    "typescript-eslint": "^8.0.0"
  },
  "overrides": {
    "shell-quote": "^1.8.4"
  },
  "engines": {
    "node": ">=20"
  }
}
