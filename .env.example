# SiteCRM environment variables
# Copy to .env at the repo root and fill in values.
# The .env file is loaded automatically by apps/server and apps/intelligence.

# ── Database ──────────────────────────────────────────────────────────────────
# Local Docker Compose database (matches docker-compose.yml defaults):
DATABASE_URL=postgres://sitecrm:sitecrm@localhost:5432/sitecrm

# Neon (production): replace with your Neon connection string
# DATABASE_URL=postgres://user:password@ep-xxx.us-east-1.aws.neon.tech/sitecrm?sslmode=require

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-strong-random-secret

# ── Intelligence API ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
INTELLIGENCE_API_URL=http://localhost:3001

# ── Meta (Facebook / Instagram) ───────────────────────────────────────────────
# Obtained from Meta for Developers → Your App → Settings → Basic
# META_APP_ID=
# META_APP_SECRET=
# META_WEBHOOK_VERIFY_TOKEN=change-me-to-a-random-string

# ── Email (Resend) ────────────────────────────────────────────────────────────
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@yourdomain.com

# ── AWS (hosting dashboard) ───────────────────────────────────────────────────
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# TERRAFORM_STATE_BUCKET=sitecrm-terraform-state
