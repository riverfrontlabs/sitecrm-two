# Copy to terraform.tfvars and adjust. Every value is optional — the
# defaults in variables.tf stand up a working dev environment as-is.

# aws_region    = "us-east-1"
# environment   = "dev"
# project_name  = "sitecrm"

# API image tag to deploy from ECR (see README.md for the push workflow).
# api_image_tag     = "latest"
# api_desired_count = 1

# Intelligence service image + sizing (Playwright + OpenAI; heavier than the API).
# intelligence_image_tag     = "latest"
# intelligence_desired_count = 1
# intelligence_cpu           = 512
# intelligence_memory        = 1024

# Database sizing.
# db_instance_class    = "db.t4g.micro"
# db_allocated_storage = 20

# Secrets — NEVER put real values here; pass via environment variables:
#   export TF_VAR_jwt_secret=$(openssl rand -hex 32)   # optional; auto-generated if unset
#   export TF_VAR_openai_api_key=sk-...                # required for the Intelligence service
# jwt_secret     = ""
# openai_api_key = ""
